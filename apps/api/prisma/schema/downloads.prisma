model DownloadJob {
  id String @id @default(uuid())

  status       DownloadJobSatatus
  fileName     String?
  filePath     String?
  progress     Int                @default(0)
  errorMessage String?
  expiresAt    DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  items DownloadJobItem[]
}

model DownloadJobItem {
  id String @id @default(uuid())

  itemKind FileSystemItemKind
  itemId   String

  job   DownloadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId String

  @@index([jobId])
}

enum DownloadJobSatatus {
  pending
  processing
  ready
  failed
  expired
}
