// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model File {
  id           String   @id @default(uuid())
  originalName String
  diskName     String
  size         Int
  mimeType     String
  createdAt    DateTime @default(now())
}
