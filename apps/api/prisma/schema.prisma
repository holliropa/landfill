// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model File {
  id String @id @default(uuid())

  originalName String
  diskName     String
  size         Int
  mimeType     String

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([folderId])
}

model Folder {
  id String @id @default(uuid())

  name String

  parentFolderId  String?
  parentFolder    Folder?  @relation("FolderTree", fields: [parentFolderId], references: [id], onDelete: Cascade)
  childrenFolders Folder[] @relation("FolderTree")
  files           File[]

  createdAt DateTime @default(now())

  @@unique([parentFolderId, name])
  @@index([parentFolderId])
}

model DownloadJob {
  id String @id @default(uuid())

  status       DownloadJobSatatus
  fileName     String?
  filePath     String?
  progress     Int                @default(0)
  errorMessage String?
  expiresAt    DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  items DownloadJobItem[]
}

model DownloadJobItem {
  id String @id @default(uuid())

  itemKind DownloadItemKind
  itemId   String

  job   DownloadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId String

  @@index([jobId])
}

enum DownloadItemKind {
  file
  folder
}

enum DownloadJobSatatus {
  pending
  processing
  ready
  failed
  expired
}
